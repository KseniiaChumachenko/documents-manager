{
  "name": "infra",
  "main": "dist/index.js",
  "version": "0.0.0",
  "dependencies": {
    "@pulumi/cloudflare": "^6.3.1",
    "@pulumi/command": "^1.1.0",
    "@pulumi/pulumi": "^3.178.0"
  },
  "scripts": {
    "build": "tsc",
    "deploy:staging": "pulumi up --stack staging --yes",
    "deploy:production": "pulumi up --stack production --yes",
    "destroy:staging": "pulumi destroy --stack staging",
    "destroy:production": "pulumi destroy --stack production",
    "refresh:staging": "pulumi refresh --stack staging",
    "refresh:production": "pulumi refresh --stack production",
    "output:staging": "pulumi stack output --stack staging",
    "output:production": "pulumi stack output --stack production"
  },
  "nx": {
    "targets": {
      "deploy": {
        "cache": true,
        "dependsOn": [
          "build",
          "website:generate"
        ]
      },
      "destroy": {
        "dependsOn": [
          "build"
        ]
      }
    }
  },
  "devDependencies": {}
}
