{
  "$schema": "https://opencode.ai/config.json",
  "model": "zai/glm-5",
  "instructions": [".claude/CLAUDE.md", ".claude/memory/*.md", ".claude/plans/*.md"],
  "watcher": {
    "ignore": [
      "node_modules/**",
      "apps/web/build/**",
      "apps/web/.react-router/**",
      "apps/web/.wrangler/**",
      ".nx/**",
      "apps/web/test-results/**",
      "apps/web/playwright-report/**"
    ]
  },
  "mcp": {
    "nx-mcp": {
      "type": "local",
      "command": ["npx", "nx-mcp"],
      "enabled": true
    }
  }
}
